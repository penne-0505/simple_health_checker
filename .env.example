# Required
DISCORD_BOT_TOKEN=your_bot_token_here

# Optional: for faster slash command registration during development
COMMAND_GUILD_ID=

# SQLite file path
SQLITE_PATH=./data/health_checker.sqlite3

# Scheduler
POLL_LOOP_SECONDS=2
MAX_PARALLEL_CHECKS=10

# Optional summary report
SUMMARY_CHANNEL_ID=
SUMMARY_INTERVAL_SECONDS=3600

# HTTP request metadata
REQUEST_USER_AGENT=simple-health-checker/0.1.0
